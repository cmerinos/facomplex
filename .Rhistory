col <- as.ordered(col)
}
}
return(col)
}))
n.items <- ncol(data)
item.names <- colnames(data)
if (is.null(item.names)) item.names <- paste0("Item", 1:n.items)
n.obs <- nrow(data)
# ---------- Función para pseudo-R² ----------
# Recibe los modelos ajustados (con lrm) y devuelve el R² del tipo elegido
get_pseudo_R2 <- function(model, null_model, type = r2.type, n = n.obs) {
ll <- as.numeric(logLik(model))
ll_null <- as.numeric(logLik(null_model))
if (type == "nag") {
R2_cs <- 1 - exp((ll_null - ll) * 2 / n)
return(R2_cs / (1 - exp(2 * ll_null / n)))
} else if (type == "cox") {
return(1 - exp((ll_null - ll) * 2 / n))
} else if (type == "mcf") {
return(1 - ll / ll_null)
} else if (type == "mcfad") {
k <- length(coef(model))
return(1 - (ll - k) / ll_null)
} else {
stop("Tipo de R² no reconocido")
}
}
# ---------- Función para analizar un ítem con una x dada ----------
analyze_item <- function(item, x) {
# Ajustar modelos
m0 <- lrm(item ~ 1, x = TRUE, y = TRUE)          # modelo nulo
m1 <- lrm(item ~ x, x = TRUE, y = TRUE)          # solo score
m2 <- lrm(item ~ x + group, x = TRUE, y = TRUE)  # + grupo (uniforme)
m3 <- lrm(item ~ x + group + group:x, x = TRUE, y = TRUE) # + interacción
# Log-verosimilitudes y grados de libertad
ll0 <- logLik(m0); ll1 <- logLik(m1); ll2 <- logLik(m2); ll3 <- logLik(m3)
df0 <- attr(ll0, "df"); df1 <- attr(ll1, "df"); df2 <- attr(ll2, "df"); df3 <- attr(ll3, "df")
# R² de cada modelo (usando el nulo)
r2_0 <- get_pseudo_R2(m0, m0)  # da 0 para todos los tipos
r2_1 <- get_pseudo_R2(m1, m0)
r2_2 <- get_pseudo_R2(m2, m0)
r2_3 <- get_pseudo_R2(m3, m0)
# ---------- UNIFORME (M2 vs M1) ----------
if (test == "LRT") {
stat_u <- -2 * (as.numeric(ll1) - as.numeric(ll2))
df_u <- df2 - df1
p_u <- 1 - pchisq(stat_u, df_u)
} else { # Wald sobre el coeficiente de group
coef_m2 <- coef(m2)
vcov_m2 <- vcov(m2)
idx_g <- grep("^group", names(coef_m2))
if (length(idx_g) == 0) {
stat_u <- NA; p_u <- NA
} else {
z <- coef_m2[idx_g] / sqrt(vcov_m2[idx_g, idx_g])
stat_u <- z^2
p_u <- 2 * pnorm(-abs(z))
}
}
dr2_u <- r2_2 - r2_1   # cambio de R² al añadir grupo
coef_m2 <- coef(m2)
idx_g <- grep("^group", names(coef_m2))
beta_u <- if (length(idx_g) == 1) coef_m2[idx_g] else NA
delta_u <- -2.35 * beta_u
or_u <- exp(beta_u)
# ---------- NO UNIFORME (M3 vs M2) ----------
if (test == "LRT") {
stat_n <- -2 * (as.numeric(ll2) - as.numeric(ll3))
df_n <- df3 - df2
p_n <- 1 - pchisq(stat_n, df_n)
} else { # Wald sobre interacción
coef_m3 <- coef(m3)
vcov_m3 <- vcov(m3)
idx_i <- grep("group.*:x|:group", names(coef_m3))
if (length(idx_i) == 0) {
stat_n <- NA; p_n <- NA
} else {
z <- coef_m3[idx_i] / sqrt(vcov_m3[idx_i, idx_i])
stat_n <- z^2
p_n <- 2 * pnorm(-abs(z))
}
}
dr2_n <- r2_3 - r2_2
coef_m3 <- coef(m3)
idx_i <- grep("group.*:x|:group", names(coef_m3))
beta_n <- if (length(idx_i) == 1) coef_m3[idx_i] else NA
delta_n <- -2.35 * beta_n
or_n <- exp(beta_n)
# ---------- SIMULTÁNEO (M3 vs M1) ----------
if (test == "LRT") {
stat_b <- -2 * (as.numeric(ll1) - as.numeric(ll3))
df_b <- df3 - df1
p_b <- 1 - pchisq(stat_b, df_b)
} else { # Wald conjunto (group + interacción)
coef_m3 <- coef(m3)
vcov_m3 <- vcov(m3)
idx_g <- grep("^group", names(coef_m3))
idx_i <- grep("group.*:x|:group", names(coef_m3))
if (length(idx_g) == 0 || length(idx_i) == 0) {
stat_b <- NA; p_b <- NA
} else {
b <- coef_m3[c(idx_g, idx_i)]
V <- vcov_m3[c(idx_g, idx_i), c(idx_g, idx_i)]
if (any(is.na(V)) || det(V) == 0) {
stat_b <- NA; p_b <- NA
} else {
stat_b <- t(b) %*% solve(V) %*% b
p_b <- 1 - pchisq(stat_b, df = 2)
}
}
}
dr2_b <- r2_3 - r2_1   # cambio de R² al añadir grupo e interacción
# Devolver todo
list(
stat_u = stat_u, p_u = p_u, dr2_u = dr2_u, beta_u = beta_u, delta_u = delta_u, or_u = or_u,
stat_n = stat_n, p_n = p_n, dr2_n = dr2_n, beta_n = beta_n, delta_n = delta_n, or_n = or_n,
stat_b = stat_b, p_b = p_b, dr2_b = dr2_b
)
}
# ---------- Purificación iterativa ----------
if (purify) {
x <- x0
iter <- 0
dif_items_prev <- rep(FALSE, n.items)
dif_items <- rep(FALSE, n.items)
history <- list()
repeat {
iter <- iter + 1
results <- vector("list", n.items)
for (i in 1:n.items) {
results[[i]] <- analyze_item(data[[i]], x)
}
# Determinar ítems DIF según el criterio
if (purify.criterion == "uniform") {
p_vals <- sapply(results, function(r) r$p_u)
} else {
p_vals <- sapply(results, function(r) r$p_b)
}
dif_items <- p_vals < alpha
history[[iter]] <- list(iter = iter, dif_items = which(dif_items), p_vals = p_vals)
if (identical(dif_items, dif_items_prev) || iter >= max.iter) break
non_dif <- !dif_items
if (sum(non_dif) == 0) {
warning("No quedan ítems no DIF; se detiene purificación")
break
}
x <- rowSums(data[, non_dif, drop = FALSE], na.rm = FALSE)
dif_items_prev <- dif_items
}
final_results <- results
purif_history <- history
} else {
x <- x0
final_results <- vector("list", n.items)
for (i in 1:n.items) {
final_results[[i]] <- analyze_item(data[[i]], x)
}
purif_history <- NULL
}
# ---------- Dataframes de salida ----------
df_uniform <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_u),
p_value = sapply(final_results, function(r) r$p_u),
dR2 = sapply(final_results, function(r) r$dr2_u),
Beta = sapply(final_results, function(r) r$beta_u),
Delta = sapply(final_results, function(r) r$delta_u),
OR = sapply(final_results, function(r) r$or_u),
row.names = NULL, stringsAsFactors = FALSE
)
df_nonuniform <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_n),
p_value = sapply(final_results, function(r) r$p_n),
dR2 = sapply(final_results, function(r) r$dr2_n),
Beta = sapply(final_results, function(r) r$beta_n),
Delta = sapply(final_results, function(r) r$delta_n),
OR = sapply(final_results, function(r) r$or_n),
row.names = NULL, stringsAsFactors = FALSE
)
df_simult <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_b),
p_value = sapply(final_results, function(r) r$p_b),
dR2 = sapply(final_results, function(r) r$dr2_b),
row.names = NULL, stringsAsFactors = FALSE
)
out <- list(
uniform = df_uniform,
nonuniform = df_nonuniform,
simultaneous = df_simult
)
if (purify) {
out$purification <- purif_history
}
class(out) <- "ordinal_DIF"
return(out)
}
OLRDIF(data = data.bfi[, 1:5], group = data.bfi$gender, r2.type = "nag", test = "Wald", purify = F, match.score = "sum")
MeasInv::DIF.Logistic.MG
#' Differential Item Functioning for Ordinal Polytomous Items using Logistic Regression
#'
#' @param data data.frame con ítems (columnas). Se asume que cada ítem es numérico o factor ordenado.
#' @param group vector o factor con los grupos (puede tener más de dos niveles).
#' @param r2.type tipo de pseudo-R²: "nag" (Nagelkerke), "cox" (Cox-Snell), "mcf" (McFadden), "mcfad" (McFadden ajustado).
#' @param test tipo de prueba: "LRT" (razón de verosimilitudes) o "Wald".
#' @param effect.measure métrica de tamaño del efecto a mostrar: "dR2" (defecto), "delta", "beta", o "all" para todas.
#'   Nota: si group tiene más de 2 niveles, solo se mostrará "dR2" (las demás se ignoran).
#' @param match.score "sum" (suma de todos los ítems) o un vector numérico de la misma longitud que nrow(data).
#' @param purify lógico; si TRUE (defecto) se realiza purificación iterativa.
#' @param purify.criterion prueba usada para purificar: "uniform" o "simultaneous" (defecto "simultaneous").
#' @param max.iter número máximo de iteraciones en purificación (defecto 10).
#' @param alpha nivel de significación (defecto 0.05).
#'
#' @return Lista con dataframes: uniform, nonuniform, simultaneous, y (si purify) purification.
#' @export
#' @import rms
OLRDIF <- function(data, group,
r2.type = c("nag", "cox", "mcf", "mcfad"),
test = c("LRT", "Wald"),
effect.measure = c("dR2", "delta", "beta", "all"),
match.score = "sum",
purify = TRUE,
purify.criterion = c("simultaneous", "uniform"),
max.iter = 10,
alpha = 0.05) {
# ---------- Validación de argumentos ----------
r2.type <- match.arg(r2.type)
test <- match.arg(test)
effect.measure <- match.arg(effect.measure)
purify.criterion <- match.arg(purify.criterion)
if (!is.data.frame(data)) stop("'data' debe ser un data.frame")
if (ncol(data) < 2) stop("Se necesitan al menos 2 ítems")
if (length(group) != nrow(data)) stop("'group' debe tener la misma longitud que nrow(data)")
group <- as.factor(group)
n.groups <- nlevels(group)
if (n.groups < 2) stop("'group' debe tener al menos dos niveles")
# Si hay más de 2 grupos, forzar effect.measure = "dR2" y advertir
if (n.groups > 2 && effect.measure != "dR2") {
warning("Hay más de 2 grupos. Solo se mostrará 'dR2' como medida de efecto. ",
"Beta, Delta y OR no están disponibles para múltiples grupos.")
effect.measure <- "dR2"
}
# Puntuación de referencia
if (is.character(match.score) && match.score == "sum") {
x0 <- rowSums(data, na.rm = FALSE)
} else if (is.numeric(match.score) && length(match.score) == nrow(data)) {
x0 <- match.score
} else {
stop("'match.score' debe ser 'sum' o un vector numérico de longitud nrow(data)")
}
# Eliminar casos con missing
complete <- complete.cases(data, x0)
if (any(!complete)) {
warning("Se eliminan ", sum(!complete), " casos con missing")
data <- data[complete, ]
group <- group[complete]
x0 <- x0[complete]
}
# Asegurar que los ítems sean factores ordenados (si no lo son)
data <- as.data.frame(lapply(data, function(col) {
if (!is.ordered(col)) {
if (is.numeric(col)) {
col <- factor(col, levels = sort(unique(col)), ordered = TRUE)
} else {
col <- as.ordered(col)
}
}
return(col)
}))
n.items <- ncol(data)
item.names <- colnames(data)
if (is.null(item.names)) item.names <- paste0("Item", 1:n.items)
n.obs <- nrow(data)
# ---------- Función para calcular pseudo-R² ----------
get_pseudo_R2 <- function(model, null_model, type = r2.type, n = n.obs) {
ll <- as.numeric(logLik(model))
ll_null <- as.numeric(logLik(null_model))
if (type == "nag") {
R2_cs <- 1 - exp((ll_null - ll) * 2 / n)
return(R2_cs / (1 - exp(2 * ll_null / n)))
} else if (type == "cox") {
return(1 - exp((ll_null - ll) * 2 / n))
} else if (type == "mcf") {
return(1 - ll / ll_null)
} else if (type == "mcfad") {
k <- length(coef(model))
return(1 - (ll - k) / ll_null)
} else {
stop("Tipo de R² no reconocido")
}
}
# ---------- Función para analizar un ítem con una x dada ----------
analyze_item <- function(item, x) {
temp_data <- data.frame(item = item, x = x, group = group)
m0 <- rms::lrm(item ~ 1, data = temp_data, x = TRUE, y = TRUE)
m1 <- rms::lrm(item ~ x, data = temp_data, x = TRUE, y = TRUE)
m2 <- rms::lrm(item ~ x + group, data = temp_data, x = TRUE, y = TRUE)
m3 <- rms::lrm(item ~ x + group + group:x, data = temp_data, x = TRUE, y = TRUE)
ll0 <- logLik(m0); ll1 <- logLik(m1); ll2 <- logLik(m2); ll3 <- logLik(m3)
df0 <- attr(ll0, "df"); df1 <- attr(ll1, "df"); df2 <- attr(ll2, "df"); df3 <- attr(ll3, "df")
r2_1 <- get_pseudo_R2(m1, m0)
r2_2 <- get_pseudo_R2(m2, m0)
r2_3 <- get_pseudo_R2(m3, m0)
# ---------- UNIFORME (M2 vs M1) ----------
if (test == "LRT") {
stat_u <- -2 * (as.numeric(ll1) - as.numeric(ll2))
df_u <- df2 - df1
p_u <- 1 - pchisq(stat_u, df_u)
} else { # Wald sobre coeficientes de group
coef_m2 <- coef(m2)
vcov_m2 <- vcov(m2)
idx_g <- grep("^group", names(coef_m2))
if (length(idx_g) == 0) {
stat_u <- NA; p_u <- NA
} else {
b <- coef_m2[idx_g]
V <- vcov_m2[idx_g, idx_g]
if (any(is.na(V)) || det(V) == 0) {
stat_u <- NA; p_u <- NA
} else {
stat_u <- t(b) %*% solve(V) %*% b
p_u <- 1 - pchisq(stat_u, df = length(idx_g))
}
}
}
dr2_u <- r2_2 - r2_1
# Coeficientes de group (solo si hay exactamente 2 grupos)
if (n.groups == 2) {
coef_m2 <- coef(m2)
idx_g <- grep("^group", names(coef_m2))
beta_u <- if (length(idx_g) == 1) coef_m2[idx_g] else NA
delta_u <- -2.35 * beta_u
or_u <- exp(beta_u)
} else {
beta_u <- NA
delta_u <- NA
or_u <- NA
}
# ---------- NO UNIFORME (M3 vs M2) ----------
if (test == "LRT") {
stat_n <- -2 * (as.numeric(ll2) - as.numeric(ll3))
df_n <- df3 - df2
p_n <- 1 - pchisq(stat_n, df_n)
} else { # Wald sobre interacciones
coef_m3 <- coef(m3)
vcov_m3 <- vcov(m3)
idx_i <- grep("group.*:x|:group", names(coef_m3))
if (length(idx_i) == 0) {
stat_n <- NA; p_n <- NA
} else {
b <- coef_m3[idx_i]
V <- vcov_m3[idx_i, idx_i]
if (any(is.na(V)) || det(V) == 0) {
stat_n <- NA; p_n <- NA
} else {
stat_n <- t(b) %*% solve(V) %*% b
p_n <- 1 - pchisq(stat_n, df = length(idx_i))
}
}
}
dr2_n <- r2_3 - r2_2
if (n.groups == 2) {
coef_m3 <- coef(m3)
idx_i <- grep("group.*:x|:group", names(coef_m3))
beta_n <- if (length(idx_i) == 1) coef_m3[idx_i] else NA
delta_n <- -2.35 * beta_n
or_n <- exp(beta_n)
} else {
beta_n <- NA
delta_n <- NA
or_n <- NA
}
# ---------- SIMULTÁNEO (M3 vs M1) ----------
if (test == "LRT") {
stat_b <- -2 * (as.numeric(ll1) - as.numeric(ll3))
df_b <- df3 - df1
p_b <- 1 - pchisq(stat_b, df_b)
} else { # Wald conjunto de group + interacciones
coef_m3 <- coef(m3)
vcov_m3 <- vcov(m3)
idx_g <- grep("^group", names(coef_m3))
idx_i <- grep("group.*:x|:group", names(coef_m3))
if (length(idx_g) == 0 || length(idx_i) == 0) {
stat_b <- NA; p_b <- NA
} else {
b <- coef_m3[c(idx_g, idx_i)]
V <- vcov_m3[c(idx_g, idx_i), c(idx_g, idx_i)]
if (any(is.na(V)) || det(V) == 0) {
stat_b <- NA; p_b <- NA
} else {
stat_b <- t(b) %*% solve(V) %*% b
p_b <- 1 - pchisq(stat_b, df = length(idx_g) + length(idx_i))
}
}
}
dr2_b <- r2_3 - r2_1
list(
stat_u = stat_u, p_u = p_u, dr2_u = dr2_u, beta_u = beta_u, delta_u = delta_u, or_u = or_u,
stat_n = stat_n, p_n = p_n, dr2_n = dr2_n, beta_n = beta_n, delta_n = delta_n, or_n = or_n,
stat_b = stat_b, p_b = p_b, dr2_b = dr2_b
)
}
# ---------- Purificación iterativa ----------
if (purify) {
x <- x0
iter <- 0
dif_items_prev <- rep(FALSE, n.items)
dif_items <- rep(FALSE, n.items)
history <- list()
repeat {
iter <- iter + 1
results <- vector("list", n.items)
for (i in 1:n.items) {
results[[i]] <- analyze_item(data[[i]], x)
}
if (purify.criterion == "uniform") {
p_vals <- sapply(results, function(r) r$p_u)
} else {
p_vals <- sapply(results, function(r) r$p_b)
}
dif_items <- p_vals < alpha
history[[iter]] <- list(iter = iter, dif_items = which(dif_items), p_vals = p_vals)
if (identical(dif_items, dif_items_prev) || iter >= max.iter) break
non_dif <- !dif_items
if (sum(non_dif) == 0) {
warning("No quedan ítems no DIF; se detiene purificación")
break
}
x <- rowSums(data[, non_dif, drop = FALSE], na.rm = FALSE)
dif_items_prev <- dif_items
}
final_results <- results
purif_history <- history
} else {
x <- x0
final_results <- vector("list", n.items)
for (i in 1:n.items) {
final_results[[i]] <- analyze_item(data[[i]], x)
}
purif_history <- NULL
}
# ---------- Construcción de dataframes de salida ----------
# Definir columnas según effect.measure y número de grupos
if (n.groups == 2) {
# Para dos grupos, se pueden mostrar todas las métricas
if (effect.measure == "dR2") {
cols_u <- c("Item", "Statistic", "p_value", "dR2")
cols_n <- c("Item", "Statistic", "p_value", "dR2")
} else if (effect.measure == "delta") {
cols_u <- c("Item", "Statistic", "p_value", "Delta")
cols_n <- c("Item", "Statistic", "p_value", "Delta")
} else if (effect.measure == "beta") {
cols_u <- c("Item", "Statistic", "p_value", "Beta")
cols_n <- c("Item", "Statistic", "p_value", "Beta")
} else { # "all"
cols_u <- c("Item", "Statistic", "p_value", "dR2", "Beta", "Delta", "OR")
cols_n <- c("Item", "Statistic", "p_value", "dR2", "Beta", "Delta", "OR")
}
} else {
# Para más de dos grupos, solo mostramos dR2
cols_u <- c("Item", "Statistic", "p_value", "dR2")
cols_n <- c("Item", "Statistic", "p_value", "dR2")
}
# Dataframe uniforme
df_uniform <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_u),
p_value = sapply(final_results, function(r) r$p_u),
dR2 = sapply(final_results, function(r) r$dr2_u),
Beta = sapply(final_results, function(r) r$beta_u),
Delta = sapply(final_results, function(r) r$delta_u),
OR = sapply(final_results, function(r) r$or_u),
row.names = NULL, stringsAsFactors = FALSE
)[, cols_u, drop = FALSE]
# Dataframe no uniforme
df_nonuniform <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_n),
p_value = sapply(final_results, function(r) r$p_n),
dR2 = sapply(final_results, function(r) r$dr2_n),
Beta = sapply(final_results, function(r) r$beta_n),
Delta = sapply(final_results, function(r) r$delta_n),
OR = sapply(final_results, function(r) r$or_n),
row.names = NULL, stringsAsFactors = FALSE
)[, cols_n, drop = FALSE]
# Dataframe simultáneo (siempre las mismas columnas)
df_simult <- data.frame(
Item = item.names,
Statistic = sapply(final_results, function(r) r$stat_b),
p_value = sapply(final_results, function(r) r$p_b),
dR2 = sapply(final_results, function(r) r$dr2_b),
row.names = NULL, stringsAsFactors = FALSE
)
out <- list(
uniform = df_uniform,
nonuniform = df_nonuniform,
simultaneous = df_simult
)
if (purify) {
out$purification <- purif_history
}
class(out) <- "ordinal_DIF"
return(out)
}
OLRDIF(data = data.bfi[, 1:5],
group = data.bfi$gender,
r2.type = "nag",
test = "Wald",
purify = F,
match.score = "sum")
